# Streamlit Secrets Configuration Template
# Copy this file to secrets.toml and fill in your actual values

# OpenAI
openai_key = 'your-openai-key-here'

# Jina
jina_key = 'your-jina-key-here'

# Pinecone
PINECONE_API_KEY = 'your-pinecone-key-here'
PINECONE_ENV = 'your-pinecone-env'

# MySQL (if using)
mysql_url = 'mysql+mysqlconnector://user:password@host:port/database'

# Notion (if using)
notion_secret = 'your-notion-secret'
notion_prompt_database = 'your-notion-database-id'

# Alpha Vantage (if using)
alpha_vantage_key = 'your-alpha-vantage-key'

# Tushare
tushare_token = 'your-tushare-token'
